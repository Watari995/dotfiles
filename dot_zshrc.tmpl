# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi


# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"
export VOLTA_HOME="$HOME/.volta"
export PATH=$PATH:/usr/local/bin
export PATH="$VOLTA_HOME/bin:$PATH"

ZSH_THEME="powerlevel10k/powerlevel10k"
zstyle ':omz:update' mode disabled

plugins=(git zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh
printf '\e]12;#FFFFFF\a'

# Neovim Setting
alias vi="nvim"
alias vim="nvim"

# asdf for GO
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:$PATH"


# Volta
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# Anyenv
export PATH="$HOME/.anyenv/bin:$PATH"
eval "$(anyenv init -)"
export PATH=$PATH:/Applications/MySQLWorkbench.app/Contents/Resources/utilities:/usr/local/bin:/usr/local/sbin:/usr/local/mysql/bin:/usr/local/mysql/support-files:/usr/local/mysql/lib:/usr/local/mysql/include:/usr/local/mysql/share:/usr/local/mysql
eval "source '{{ .chezmoi.homeDir }}/.anyenv/libexec/../completions/anyenv.zsh'"

anyenv() {
  typeset command
  command="$1"
  if [ "$#" -gt 0 ]; then
    shift
  fi
  command anyenv "$command" "$@"
}

export NODENV_ROOT="{{ .chezmoi.homeDir }}/.anyenv/envs/nodenv"
export PATH="{{ .chezmoi.homeDir }}/.anyenv/envs/nodenv/bin:$PATH"
export PATH="{{ .chezmoi.homeDir }}/.anyenv/envs/nodenv/shims:${PATH}"
export NODENV_SHELL=zsh
source '{{ .chezmoi.homeDir }}/.anyenv/envs/nodenv/libexec/../completions/nodenv.zsh'
command nodenv rehash 2>/dev/null
nodenv() {
  local command
  command="${1:-}"
  if [ "$#" -gt 0 ]; then
    shift
  fi
  case "$command" in
    rehash|shell)
      eval "$(nodenv "sh-$command" "$@")"
      ;;
    *)
      command nodenv "$command" "$@"
      ;;
  esac
}


# asdf setting
. /opt/homebrew/opt/asdf/libexec/asdf.sh
# asdf setting for go
go_bin_path=$(asdf where golang 2>/dev/null)/bin
if [[ -d "$go_bin_path" ]]; then
  export PATH="$go_bin_path:$PATH"
fi

# pnpm

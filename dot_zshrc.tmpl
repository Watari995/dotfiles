# Ghostty 背景透過トグル
toggle-opacity() {
  local config="$HOME/.config/ghostty/config"
  if grep -q "background-opacity = 1$" "$config"; then
    sed -i '' 's/background-opacity = 1$/background-opacity = 0.9/' "$config"
  else
    sed -i '' 's/background-opacity = [0-9.]*/background-opacity = 1/' "$config"
  fi
  # Ghosttyにリロードを通知
  killall -SIGUSR1 ghostty
}
